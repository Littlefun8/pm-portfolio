---
import { siteConfig } from "../config";

const navItems = [
  { href: "#home", label: "首页" },
  { href: "#education", label: "教育与成果" },
  { href: "#case-studies", label: "案例" },
  { href: "#thinking-vault", label: "思考库" },
  { href: "#contact", label: "联系" },
];
---

<footer
  class="bg-gray-50 border-t border-gray-200"
  style={`--accent-color: ${siteConfig.accentColor}`}
>
  <div class="mx-auto max-w-6xl px-6 py-10 lg:px-8">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
      <!-- Left: name + title -->
      <div>
        <p class="text-base font-bold text-gray-800">L</p>
        <p class="text-sm text-gray-500">{siteConfig.title}</p>
        <div class="flex gap-x-4 mt-3">
          {
            siteConfig.social?.email && (
              <a
                href={`mailto:${siteConfig.social.email}`}
                aria-label="Email"
                class="text-gray-500 transition-colors hover:text-[var(--accent-color)]"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </a>
            )
          }
          {
            siteConfig.social?.github && (
              <a
                href={siteConfig.social.github}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="GitHub"
                class="text-gray-500 transition-colors hover:text-[var(--accent-color)]"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19c-4.3 1.4-4.3-2.5-6-3m12 5v-3.5c0-1 .1-1.4-.5-2 2.8-.3 5.5-1.4 5.5-6a4.6 4.6 0 00-1.3-3.2 4.2 4.2 0 00-.1-3.2s-1.1-.3-3.5 1.3a12.3 12.3 0 00-6.2 0C6.5 2.8 5.4 3.1 5.4 3.1a4.2 4.2 0 00-.1 3.2A4.6 4.6 0 004 9.5c0 4.6 2.7 5.7 5.5 6-.6.6-.6 1.2-.5 2V21" />
                </svg>
              </a>
            )
          }
          {
            siteConfig.social?.linkedin && (
              <a
                href={siteConfig.social.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="LinkedIn"
                class="text-gray-500 transition-colors hover:text-[var(--accent-color)]"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 11v5M8 8v.01M12 16v-5M16 16v-3a2 2 0 10-4 0M3 7a4 4 0 014-4h10a4 4 0 014 4v10a4 4 0 01-4 4H7a4 4 0 01-4-4z" />
                </svg>
              </a>
            )
          }
        </div>
      </div>

      <!-- Right: nav + copyright -->
      <div class="flex flex-col items-start md:items-end gap-3">
        <nav class="flex flex-wrap gap-x-5 gap-y-2">
          {
            navItems.map((item) => (
              <a
                href={item.href}
                class="text-sm text-gray-500 hover:text-gray-800 transition-colors"
              >
                {item.label}
              </a>
            ))
          }
        </nav>
        <p class="text-xs text-gray-400">
          © {new Date().getFullYear()} L. Built with Astro.
        </p>
      </div>
    </div>
  </div>
</footer>
