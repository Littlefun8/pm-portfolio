---
import { siteConfig } from "../config";

const metrics = siteConfig.metricsBar;
---

<section
  id="metrics"
  class="py-12 md:py-16 border-y border-gray-100"
  style={`--accent-color: ${siteConfig.accentColor}`}
>
  <div class="max-w-5xl mx-auto px-8 sm:px-12 md:px-24 grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
    {metrics.map((m) => (
      <div class="group">
        <p
          class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight transition-colors duration-300"
          style={`color: ${siteConfig.accentColor}`}
        >
          {m.value}
        </p>
        <p class="text-sm text-gray-700 mt-1 font-medium">
          <span data-zh>{m.label}</span>
          <span data-en>{m.labelEn}</span>
        </p>
        <p class="text-xs text-gray-400 mt-0.5 font-mono">
          {m.source}
        </p>
      </div>
    ))}
  </div>
</section>
