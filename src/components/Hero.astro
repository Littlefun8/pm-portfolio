---
import { siteConfig } from "../config";
const base = import.meta.env.BASE_URL;
const joinWithBase = (path: string) => {
  const normalizedBase = base.endsWith("/") ? base : `${base}/`;
  return `${normalizedBase}${path.replace(/^\/+/, "")}`;
};
---

<div
  id="home"
  class="relative isolate overflow-hidden bg-white min-h-screen"
  style={`--accent-color: ${siteConfig.accentColor}`}
>
  <!-- Background gradient -->
  <div
    class="absolute inset-0 -z-10"
    style={`background: radial-gradient(ellipse 900px 1200px at 0% 0%, ${siteConfig.accentColor}35 0%, ${siteConfig.accentColor}18 25%, ${siteConfig.accentColor}08 50%, rgba(255,255,255,0.5) 75%, white 100%)`}
  >
  </div>

  <!-- Subtle grid pattern -->
  <svg
    aria-hidden="true"
    class="absolute inset-0 -z-10 size-full stroke-gray-200 [mask-image:radial-gradient(100%_100%_at_top_right,white,transparent)]"
  >
    <defs>
      <pattern
        id="hero-grid"
        x="50%"
        y={-1}
        width={200}
        height={200}
        patternUnits="userSpaceOnUse"
      >
        <path d="M.5 200V.5H200" fill="none"></path>
      </pattern>
    </defs>
    <rect fill="url(#hero-grid)" width="100%" height="100%" stroke-width={0}
    ></rect>
  </svg>

  <!-- Main content -->
  <div
    class="h-full mx-auto px-8 sm:px-12 md:px-24 pt-32 md:pt-0 md:min-h-screen flex flex-col justify-center"
  >
    <div class="flex items-center gap-8">
      <div class="flex-1 max-w-3xl">
        <!-- Greeting -->
        <p
          class="text-base sm:text-lg font-mono animate-fade-in"
          style={`color: ${siteConfig.accentColor}`}
        >
          <span data-zh>{siteConfig.hero.greeting}</span>
          <span data-en>{siteConfig.hero.greetingEn}</span>
        </p>

        <!-- Name / Identity -->
        <h1
          class="mt-3 text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight text-gray-900 animate-fade-in animation-delay-200"
        >
          <span data-zh>{siteConfig.name}</span>
          <span data-en>{siteConfig.nameEn}</span>
        </h1>
        <p
          class="mt-2 text-xl sm:text-2xl md:text-3xl font-semibold text-gray-700 animate-fade-in animation-delay-200"
        >
          <span data-zh>{siteConfig.hero.identity}</span>
          <span data-en>{siteConfig.hero.identityEn}</span>
        </p>

        <!-- 3-point overview cards -->
        <div
          class="mt-8 grid grid-cols-1 sm:grid-cols-3 gap-3 animate-fade-in animation-delay-400"
        >
          <div
            class="bg-white/70 backdrop-blur-sm border border-gray-200 rounded-xl p-4 hover:shadow-md hover:-translate-y-0.5 transition-all duration-300"
          >
            <div
              class="text-xs font-mono font-semibold uppercase tracking-widest mb-1"
              style={`color: ${siteConfig.accentColor}`}
            >
              <span data-zh>身份 Identity</span>
              <span data-en>Identity</span>
            </div>
            <p class="text-sm text-gray-700 leading-relaxed">
              <span data-zh>应届生 · 软件工程背景 · AI Native 工作流实践者</span>
              <span data-en>Fresh grad · Software Engineering · AI-Native Workflow Practitioner</span>
            </p>
          </div>
          <div
            class="bg-white/70 backdrop-blur-sm border border-gray-200 rounded-xl p-4 hover:shadow-md hover:-translate-y-0.5 transition-all duration-300"
          >
            <div
              class="text-xs font-mono font-semibold uppercase tracking-widest mb-1"
              style={`color: ${siteConfig.accentColor}`}
            >
              <span data-zh>目标 Target Role</span>
              <span data-en>Target Role</span>
            </div>
            <p class="text-sm text-gray-700 leading-relaxed">
              <span data-zh>{siteConfig.hero.targetRole}</span>
              <span data-en>{siteConfig.hero.targetRoleEn}</span>
            </p>
          </div>
          <div
            class="bg-white/70 backdrop-blur-sm border border-gray-200 rounded-xl p-4 hover:shadow-md hover:-translate-y-0.5 transition-all duration-300"
          >
            <div
              class="text-xs font-mono font-semibold uppercase tracking-widest mb-1"
              style={`color: ${siteConfig.accentColor}`}
            >
              <span data-zh>能力 Core Skills</span>
              <span data-en>Core Skills</span>
            </div>
            <p class="text-sm text-gray-700 leading-relaxed">
              <span data-zh>{siteConfig.hero.coreAbility}</span>
              <span data-en>{siteConfig.hero.coreAbilityEn}</span>
            </p>
          </div>
        </div>

        <!-- Tagline -->
        <p
          class="mt-6 text-base sm:text-lg text-gray-500 leading-relaxed animate-fade-in animation-delay-400"
        >
          {siteConfig.hero.tagline}
        </p>

        <!-- CTAs -->
        <div
          class="mt-8 flex flex-wrap items-center gap-4 animate-fade-in animation-delay-600"
        >
          <a
            href="#case-studies"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-semibold text-white transition-all duration-300 hover:opacity-90 hover:-translate-y-0.5 hover:shadow-lg"
            style={`background-color: ${siteConfig.accentColor}`}
          >
            <span data-zh>查看案例</span>
            <span data-en>View Cases</span>
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"></path>
            </svg>
          </a>
          <a
            href={joinWithBase(siteConfig.social.resumeUrl)}
            download
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-semibold text-gray-800 bg-white border border-gray-300 transition-all duration-300 hover:border-gray-400 hover:-translate-y-0.5 hover:shadow-md"
          >
            <span data-zh>下载简历</span>
            <span data-en>Download Resume</span>
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
              ></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Right side avatar -->
      <div class="hidden lg:flex lg:w-2/5 items-center justify-center">
        <div id="hero-avatar" class="relative">
          <div class="w-64 h-64 md:w-80 md:h-80 rounded-2xl overflow-hidden border-4 border-white shadow-2xl">
            <img src={joinWithBase("assets/avatar.png")} alt="徐帆" class="w-full h-full object-cover" />
          </div>
          <!-- Decorative accent -->
          <div
            class="absolute -bottom-3 -right-3 w-64 h-64 md:w-80 md:h-80 rounded-2xl border-2 -z-10"
            style={`border-color: ${siteConfig.accentColor}30`}
          ></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Social links at bottom -->
  <div
    class="absolute bottom-0 left-0 right-0 px-8 sm:px-12 md:px-24 pb-8 flex gap-x-5 text-gray-500 animate-fade-in animation-delay-800"
  >
    {
      siteConfig.social?.email && (
        <a
          href={`mailto:${siteConfig.social.email}`}
          aria-label="Email"
          title={siteConfig.social.email}
          class="transition-colors duration-300 hover:text-[var(--accent-color)]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path stroke="none" d="M0 0h24v24H0z" fill="none" />
            <path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z" />
            <path d="M3 7l9 6l9 -6" />
          </svg>
        </a>
      )
    }
    {
      siteConfig.social?.github && (
        <a
          href={siteConfig.social.github}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="transition-colors duration-300 hover:text-[var(--accent-color)]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path stroke="none" d="M0 0h24v24H0z" fill="none" />
            <path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5" />
          </svg>
        </a>
      )
    }
    {
      siteConfig.social?.linkedin && (
        <a
          href={siteConfig.social.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="transition-colors duration-300 hover:text-[var(--accent-color)]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path stroke="none" d="M0 0h24v24H0z" fill="none" />
            <path d="M8 11v5" />
            <path d="M8 8v.01" />
            <path d="M12 16v-5" />
            <path d="M16 16v-3a2 2 0 1 0 -4 0" />
            <path d="M3 7a4 4 0 0 1 4 -4h10a4 4 0 0 1 4 4v10a4 4 0 0 1 -4 4h-10a4 4 0 0 1 -4 -4z" />
          </svg>
        </a>
      )
    }
    <!-- WeChat placeholder -->
    <button
      id="wechat-btn"
      aria-label="微信"
      title="微信（点击查看二维码）"
      class="transition-colors duration-300 hover:text-[var(--accent-color)] cursor-pointer"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-6 w-6"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
        <path
          d="M16.5 10c3.038 0 5.5 2.015 5.5 4.5c0 1.397 -.778 2.645 -2 3.47l0 2.03l-1.964 -1.178a6.649 6.649 0 0 1 -1.536 .178c-3.038 0 -5.5 -2.015 -5.5 -4.5s2.462 -4.5 5.5 -4.5z"
        ></path>
        <path d="M11.197 15.698c-.69 .21 -1.43 .302 -2.197 .302a8.008 8.008 0 0 1 -2.402 -.372l-2.598 1.372v-2.538c-1.197 -1.027 -2 -2.52 -2 -4.162c0 -3.314 2.904 -6 6.5 -6c3.357 0 6.055 2.387 6.463 5.488"
        ></path>
      </svg>
    </button>

    <!-- WeChat QR popup -->
    <div
      id="wechat-popup"
      class="hidden absolute bottom-16 left-8 sm:left-12 md:left-24 bg-white border border-gray-200 rounded-xl shadow-xl p-4 z-10"
    >
      <p class="text-xs text-gray-500 mb-2 text-center">微信扫码联系</p>
      <img src={joinWithBase("assets/wechat-qr.png")} alt="微信二维码" class="w-32 h-32 rounded-lg object-contain mx-auto" />
    </div>
  </div>
</div>

<script>
  const wechatBtn = document.getElementById("wechat-btn");
  const wechatPopup = document.getElementById("wechat-popup");

  wechatBtn?.addEventListener("click", (e) => {
    e.stopPropagation();
    wechatPopup?.classList.toggle("hidden");
  });

  // Close popup when clicking outside (stop propagation on popup itself)
  wechatPopup?.addEventListener("click", (e) => {
    e.stopPropagation();
  });

  document.addEventListener("click", () => {
    wechatPopup?.classList.add("hidden");
  });
</script>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fadeIn 0.8s ease-out forwards;
    opacity: 0;
  }

  .animation-delay-200 {
    animation-delay: 0.2s;
  }

  .animation-delay-400 {
    animation-delay: 0.4s;
  }

  .animation-delay-600 {
    animation-delay: 0.6s;
  }

  .animation-delay-800 {
    animation-delay: 0.8s;
  }
</style>
