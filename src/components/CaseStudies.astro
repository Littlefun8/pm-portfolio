---
import { getCollection } from "astro:content";
import { siteConfig } from "../config";

const tagColors: Record<string, string> = {
  "LangChain Agent": "bg-purple-100 text-purple-700",
  "WeChat Mini Program": "bg-green-100 text-green-700",
  "OCR": "bg-yellow-100 text-yellow-700",
  "RAG": "bg-amber-100 text-amber-700",
  "Prompt Engineering": "bg-pink-100 text-pink-700",
  "AI-Native Dev": "bg-blue-100 text-blue-700",
  "Iteration": "bg-orange-100 text-orange-700",
  "Cursor": "bg-teal-100 text-teal-700",
  "Campus": "bg-lime-100 text-lime-700",
  "AI Orchestration": "bg-indigo-100 text-indigo-700",
  "Spring Boot": "bg-emerald-100 text-emerald-700",
  "Gemini API": "bg-rose-100 text-rose-700",
  "Image Gen": "bg-fuchsia-100 text-fuchsia-700",
  "Browser Use": "bg-cyan-100 text-cyan-700",
};

function tagClass(tag: string): string {
  return tagColors[tag] ?? "bg-gray-100 text-gray-700";
}

// Fetch all cases, group by slug (without lang suffix)
const allCases = await getCollection("cases");

// Astro v5 glob loader strips dots from filenames: "dear-li-hua.zh" becomes "dear-li-huazh"
// Use the lang frontmatter field to split instead
function baseSlug(id: string, lang: string): string {
  return id.slice(0, -lang.length); // e.g. "dear-li-huazh" - "zh" = "dear-li-hua"
}

// Group into { slug: { zh: entry, en: entry } }
const grouped: Record<string, { zh?: typeof allCases[number]; en?: typeof allCases[number] }> = {};
for (const entry of allCases) {
  const slug = baseSlug(entry.id, entry.data.lang);
  if (!grouped[slug]) grouped[slug] = {};
  grouped[slug][entry.data.lang] = entry;
}

// Ordered list of slugs (preserve original order)
const caseOrder = ["dear-li-hua", "jiangcai-referral", "easyfit-ai"];
const cases = caseOrder
  .filter((s) => grouped[s])
  .map((s) => ({
    id: s,
    zh: grouped[s].zh!,
    en: grouped[s].en!,
  }));
---

<section
  id="case-studies"
  class="p-8 sm:p-12 md:p-16 lg:p-24 bg-gray-50"
  style={`--accent-color: ${siteConfig.accentColor}`}
>
  <!-- Section heading -->
  <div class="mb-10 lg:mb-14">
    <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-6xl font-bold text-gray-900">
      <span data-zh>案例</span>
      <span data-en>Case Studies</span>
    </h2>
    <p class="text-sm sm:text-base font-mono text-gray-400 mt-1">
      <span data-zh>Case Studies</span>
      <span data-en>案例</span>
    </p>
    <div
      class="w-16 h-1 mt-3 rounded-full"
      style={`background-color: ${siteConfig.accentColor}`}
    >
    </div>
    <p class="mt-4 text-base text-gray-500 max-w-2xl">
      <span data-zh>三个从真实痛点出发的产品实践案例，展示"问题定义 → 关键决策 → 产出闭环"的 AI PM 思维链路。</span>
      <span data-en>Three product cases grounded in real pain points, demonstrating "Problem Definition → Key Decisions → Deliverable Closure" AI PM thinking.</span>
    </p>
  </div>

  <!-- Case study cards -->
  <div class="space-y-6">
    {
      cases.map((cs, index) => {
        const zh = cs.zh.data;
        const en = cs.en.data;
        return (
        <div
          class="bg-white rounded-2xl border border-gray-200 overflow-hidden hover:shadow-lg transition-all duration-300"
          id={`case-card-${cs.id}`}
        >
          {/* Card header */}
          <div class="p-6 sm:p-8">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-2">
                  <span
                    class="text-xs font-mono font-bold"
                    style={`color: ${siteConfig.accentColor}`}
                  >
                    0{index + 1}
                  </span>
                  <h3 class="text-xl sm:text-2xl font-bold text-gray-900">
                    <span data-zh>{zh.name}</span>
                    <span data-en>{en.nameEn}</span>
                  </h3>
                </div>
                <p class="text-base text-gray-600 leading-relaxed font-medium">
                  <span data-zh>{zh.tagline}</span>
                  <span data-en>{en.taglineEn}</span>
                </p>
                <div class="flex flex-wrap gap-2 mt-4">
                  {zh.tags.map((tag: string) => (
                    <span
                      class={`px-2.5 py-1 rounded-full text-xs font-medium ${tagClass(tag)}`}
                    >
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
              <button
                class="case-toggle flex-shrink-0 inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium border transition-all duration-200 hover:-translate-y-0.5"
                data-target={`case-detail-${cs.id}`}
                style={`border-color: ${siteConfig.accentColor}; color: ${siteConfig.accentColor}`}
              >
                <span data-zh>查看详情</span>
                <span data-en>View Details</span>
                <svg
                  class="toggle-arrow w-4 h-4 transition-transform duration-300"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 9l-7 7-7-7"
                  />
                </svg>
              </button>
            </div>
          </div>

          {/* Expandable detail panel */}
          <div
            id={`case-detail-${cs.id}`}
            class="case-detail hidden border-t border-gray-100"
          >
            <div class="p-6 sm:p-8 space-y-8">
              {/* Layer 1: Context */}
              <div>
                <h4
                  class="text-xs font-mono font-bold uppercase tracking-widest mb-4 flex items-center gap-2"
                  style={`color: ${siteConfig.accentColor}`}
                >
                  <span class="w-5 h-5 rounded-full text-white flex items-center justify-center text-[10px] font-bold" style={`background-color: ${siteConfig.accentColor}`}>1</span>
                  <span data-zh>Context — 概览</span>
                  <span data-en>Context — Overview</span>
                </h4>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div class="bg-gray-50 rounded-xl p-4">
                    <p class="text-xs font-mono text-gray-400 mb-1">
                      <span data-zh>项目概述</span>
                      <span data-en>Summary</span>
                    </p>
                    <p class="text-sm text-gray-700 leading-relaxed">
                      <span data-zh>{zh.summary}</span>
                      <span data-en>{en.summaryEn}</span>
                    </p>
                  </div>
                  <div class="space-y-3">
                    <div class="bg-gray-50 rounded-xl p-4">
                      <p class="text-xs font-mono text-gray-400 mb-1">
                        <span data-zh>核心痛点</span>
                        <span data-en>Pain Point</span>
                      </p>
                      <p class="text-sm text-gray-700 leading-relaxed">
                        <span data-zh>{zh.problem}</span>
                        <span data-en>{en.problemEn}</span>
                      </p>
                    </div>
                    <div class="bg-gray-50 rounded-xl p-4">
                      <p class="text-xs font-mono text-gray-400 mb-1">
                        <span data-zh>用户</span>
                        <span data-en>Users</span>
                      </p>
                      <p class="text-sm text-gray-700 leading-relaxed">
                        <span data-zh>{zh.users}</span>
                        <span data-en>{en.usersEn}</span>
                      </p>
                    </div>
                    <div class="bg-gray-50 rounded-xl p-4">
                      <p class="text-xs font-mono text-gray-400 mb-1">
                        <span data-zh>项目阶段</span>
                        <span data-en>Stage</span>
                      </p>
                      <p class="text-sm text-gray-700 leading-relaxed">
                        <span data-zh>{zh.stage}</span>
                        <span data-en>{en.stageEn}</span>
                      </p>
                    </div>
                  </div>
                </div>
              </div>

              {/* Layer 2: Decisions */}
              <div>
                <h4
                  class="text-xs font-mono font-bold uppercase tracking-widest mb-4 flex items-center gap-2"
                  style={`color: ${siteConfig.accentColor}`}
                >
                  <span class="w-5 h-5 rounded-full text-white flex items-center justify-center text-[10px] font-bold" style={`background-color: ${siteConfig.accentColor}`}>2</span>
                  <span data-zh>Decisions — 问题定义与关键决策</span>
                  <span data-en>Decisions — Problem Definition & Key Decisions</span>
                </h4>
                <div class="space-y-4">
                  {zh.decisions.map((d: any, di: number) => (
                    <div class="border-l-2 pl-4" style={`border-color: ${siteConfig.accentColor}`}>
                      <h5 class="text-sm font-semibold text-gray-900 mb-1">
                        <span data-zh>{d.title}</span>
                        <span data-en>{d.titleEn}</span>
                      </h5>
                      <p class="text-sm text-gray-600 leading-relaxed">
                        <span data-zh>{d.content}</span>
                        <span data-en>{en.decisions[di]?.contentEn}</span>
                      </p>
                    </div>
                  ))}
                </div>
              </div>

              {/* Layer 3: Artifacts */}
              <div>
                <h4
                  class="text-xs font-mono font-bold uppercase tracking-widest mb-4 flex items-center gap-2"
                  style={`color: ${siteConfig.accentColor}`}
                >
                  <span class="w-5 h-5 rounded-full text-white flex items-center justify-center text-[10px] font-bold" style={`background-color: ${siteConfig.accentColor}`}>3</span>
                  <span data-zh>Artifacts — 产出文档</span>
                  <span data-en>Artifacts — Deliverables</span>
                </h4>
                <div class="flex flex-wrap gap-3">
                  {zh.artifacts.map((art: any) => (
                    <a
                      href={art.url}
                      class="group inline-flex flex-col gap-1 px-4 py-3 bg-gray-50 hover:bg-white rounded-xl border border-gray-200 hover:border-gray-300 hover:shadow-sm transition-all duration-200"
                    >
                      <span class="text-xs font-mono text-gray-400">
                        {art.type}
                      </span>
                      <span class="text-sm font-medium text-gray-800 group-hover:text-gray-900">
                        {art.label}
                      </span>
                      {art.note && (
                        <span class="text-[10px] text-gray-400 italic">
                          {art.note}
                        </span>
                      )}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      );
      })
    }
  </div>
</section>

<script>
  document.querySelectorAll(".case-toggle").forEach((btn) => {
    btn.addEventListener("click", () => {
      const targetId = (btn as HTMLElement).dataset.target;
      if (!targetId) return;
      const detail = document.getElementById(targetId);
      if (!detail) return;

      const isHidden = detail.classList.contains("hidden");
      detail.classList.toggle("hidden", !isHidden);

      const arrow = btn.querySelector(".toggle-arrow");
      arrow?.classList.toggle("rotate-180", isHidden);

      // Update bilingual button text
      const zhSpan = btn.querySelector('[data-zh]');
      const enSpan = btn.querySelector('[data-en]');
      if (zhSpan) zhSpan.textContent = isHidden ? '收起' : '查看详情';
      if (enSpan) enSpan.textContent = isHidden ? 'Collapse' : 'View Details';
    });
  });
</script>
