---
import { siteConfig } from "../config";
const edu = siteConfig.education;
---

<section
  id="education"
  class="p-8 sm:p-12 md:p-16 lg:p-24"
  style={`--accent-color: ${siteConfig.accentColor}`}
>
  <div>
    <!-- Section heading (bilingual) -->
    <div class="mb-10 lg:mb-14">
      <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-6xl font-bold text-gray-900">
        <span data-zh>教育与成果</span>
        <span data-en>Education &amp; Achievements</span>
      </h2>
      <p class="text-sm sm:text-base font-mono text-gray-400 mt-1">
        <span data-zh>Education &amp; Achievements</span>
        <span data-en>教育与成果</span>
      </p>
      <div
        class="w-16 h-1 mt-3 rounded-full"
        style={`background-color: ${siteConfig.accentColor}`}
      >
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16">
      <!-- Education card -->
      <div class="lg:col-span-5">
        <h3
          class="text-xs font-mono font-semibold uppercase tracking-widest mb-4"
          style={`color: ${siteConfig.accentColor}`}
        >
          <span data-zh>学历背景</span>
          <span data-en>Education</span>
        </h3>
        <div
          class="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-md transition-shadow duration-300"
        >
          <div class="flex items-start justify-between mb-4">
            <div>
              <h4 class="text-xl font-bold text-gray-900">
                <span data-zh>{edu.school}</span>
                <span data-en>{edu.schoolEn}</span>
              </h4>
            </div>
            <span
              class="text-xs font-mono px-2 py-1 rounded-md text-white ml-3 flex-shrink-0"
              style={`background-color: ${siteConfig.accentColor}`}
            >
              <span data-zh>2026 届</span>
              <span data-en>Class of 2026</span>
            </span>
          </div>

          <div class="mb-4">
            <p class="text-base font-semibold text-gray-700">
              <span data-zh>{edu.degree}</span>
              <span data-en>{edu.degreeEn}</span>
            </p>
          </div>

          <ul class="space-y-2">
            {
              edu.highlights.map((item) => (
                <li class="flex items-start gap-2">
                  <span
                    class="inline-block w-1.5 h-1.5 rounded-full mt-2 flex-shrink-0"
                    style={`background-color: ${siteConfig.accentColor}`}
                  />
                  <span data-zh class="text-sm text-gray-600">{item.zh}</span>
                  <span data-en class="text-sm text-gray-600">{item.en}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <!-- Milestones / Achievements -->
      <div class="lg:col-span-7">
        <h3
          class="text-xs font-mono font-semibold uppercase tracking-widest mb-4"
          style={`color: ${siteConfig.accentColor}`}
        >
          <span data-zh>成果与里程碑</span>
          <span data-en>Milestones</span>
        </h3>
        <div class="space-y-4">
          {
            edu.milestones.map((milestone, index) => (
              <div class="bg-white rounded-xl border border-gray-200 p-5 hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">
                <div class="flex items-start gap-4">
                  <div
                    class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 text-white text-sm font-bold"
                    style={`background-color: ${siteConfig.accentColor}`}
                  >
                    {index + 1}
                  </div>
                  <div>
                    <h4 class="text-base font-semibold text-gray-900 mb-1">
                      <span data-zh>{milestone.label}</span>
                      <span data-en>{milestone.labelEn}</span>
                    </h4>
                    <p class="text-sm text-gray-600 leading-relaxed">
                      <span data-zh>{milestone.desc}</span>
                      <span data-en>{milestone.descEn}</span>
                    </p>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
