---
import { siteConfig } from "../config";

const section = siteConfig.whatIDo;

// Map tech stack items to SVG icon paths (simplified devicon-style)
const techIcons: Record<string, { path: string; color: string }> = {
  "LangChain": { path: "M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5", color: "#1C3C3C" },
  "LangGraph": { path: "M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5", color: "#1C3C3C" },
  "RAG": { path: "M4 19.5A2.5 2.5 0 0 1 6.5 17H20M4 19.5A2.5 2.5 0 0 0 6.5 22H20V2H6.5A2.5 2.5 0 0 0 4 4.5v15z", color: "#3776AB" },
  "FastAPI": { path: "M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 15h-2v-2h2v2zm0-4h-2V7h2v6z", color: "#009688" },
  "Spring Boot": { path: "M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 15h-2v-2h2v2zm0-4h-2V7h2v6z", color: "#6DB33F" },
  "WeChat Mini Program": { path: "M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z", color: "#07C160" },
  "Prompt Engineering": { path: "M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z", color: "#FF6B6B" },
  "Docker": { path: "M22 12s-3-3-7.5-3c-.5 0-1 0-1.5.1V6h-2v2.2C7.7 9.1 5 12 5 12s3 5 8.5 5c.8 0 1.5-.1 2.2-.3V19h2v-3.3c2.5-1.2 4.3-3.7 4.3-3.7z", color: "#2496ED" },
  "Cloudflare": { path: "M20.4 12.3c-.1-.1-.2-.1-.3-.1.1-.4.1-.8.1-1.2 0-3.5-2.5-6.4-5.8-7-.3-2.4-2.3-4.2-4.8-4.2-2.7 0-4.8 2.1-4.8 4.8 0 .6.1 1.2.3 1.7C3.4 6.8 2 8.8 2 11.1c0 .7.1 1.4.4 2-.6.5-1 1.3-1 2.2 0 1.5 1.2 2.7 2.7 2.7h16.2c1.5 0 2.7-1.2 2.7-2.7 0-1.3-1-2.4-2.3-2.6", color: "#F48120" },
};
---

{
  section && (
    <section
      id="what-i-do"
      class="p-8 sm:p-12 md:p-16 lg:p-24"
      style={`--accent-color: ${siteConfig.accentColor}`}
    >
      <!-- Section heading -->
      <div class="mb-10 lg:mb-14 skills-reveal">
        <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-6xl font-bold text-gray-900">
          <span data-zh>{section.title}</span>
          <span data-en>{section.titleEn}</span>
        </h2>
        <p class="text-sm sm:text-base font-mono text-gray-400 mt-1">
          <span data-zh>{section.titleEn}</span>
          <span data-en>{section.title}</span>
        </p>
        <div
          class="w-16 h-1 mt-3 rounded-full"
          style={`background-color: ${siteConfig.accentColor}`}
        ></div>
        <p class="mt-4 text-base text-gray-500 max-w-3xl">
          <span data-zh>{section.intro}</span>
          <span data-en>{section.introEn}</span>
        </p>
      </div>

      <div class="flex flex-col lg:flex-row gap-12 lg:gap-16">
        <!-- Left: Tech Stack Icon Grid -->
        <div class="flex-1 skills-reveal">
          <h3 class="text-xl font-bold text-gray-900 mb-6">
            <span data-zh>AI PM / TPM 技能栈</span>
            <span data-en>AI PM / TPM Skill Stack</span>
          </h3>
          <div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-3 gap-4">
            {section.techStack.map((item) => {
              const icon = techIcons[item] || techIcons["RAG"];
              return (
                <div class="flex flex-col items-center gap-2 p-3 rounded-xl hover:bg-gray-50 transition-colors duration-200 group cursor-default">
                  <div
                    class="w-12 h-12 rounded-xl flex items-center justify-center transition-all duration-300 group-hover:scale-110"
                    style={`background: color-mix(in srgb, ${icon.color} 12%, white)`}
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="w-6 h-6"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke={icon.color}
                      stroke-width="1.8"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d={icon.path} />
                    </svg>
                  </div>
                  <span class="text-xs text-gray-600 text-center font-medium group-hover:text-gray-900 transition-colors">
                    {item}
                  </span>
                </div>
              );
            })}
          </div>
        </div>

        <!-- Right: Service/Capability bullets -->
        <div class="flex-1 skills-reveal">
          <h3 class="text-xl font-bold text-gray-900 mb-6">
            <span data-zh>核心能力</span>
            <span data-en>Core Capabilities</span>
          </h3>
          <div class="space-y-5">
            {section.capabilities.map((capability) => (
              <div class="flex gap-3">
                <span
                  class="flex-shrink-0 mt-1 text-lg"
                  style={`color: ${siteConfig.accentColor}`}
                >
                  ⚡
                </span>
                <div>
                  <h4 class="text-base font-semibold text-gray-900">
                    <span data-zh>{capability.title}</span>
                    <span data-en>{capability.titleEn}</span>
                  </h4>
                  <p class="text-sm text-gray-600 mt-1 leading-relaxed">
                    <span data-zh>{capability.description}</span>
                    <span data-en>{capability.descriptionEn}</span>
                  </p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  )
}

<script>
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  const revealNodes = document.querySelectorAll(".skills-reveal");

  if ("IntersectionObserver" in window && !prefersReducedMotion) {
    const observer = new IntersectionObserver(
      (entries, io) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add("is-visible");
          io.unobserve(entry.target);
        });
      },
      { threshold: 0.15 }
    );

    revealNodes.forEach((node) => observer.observe(node));
  } else {
    revealNodes.forEach((node) => node.classList.add("is-visible"));
  }
</script>

<style>
  .skills-reveal {
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }

  .skills-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .skills-reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>
