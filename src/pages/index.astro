---
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Education from "../components/Education.astro";
import CaseStudies from "../components/CaseStudies.astro";
import ThinkingVault from "../components/ThinkingVault.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import { siteConfig } from "../config";
import "../styles/global.css";
---

<html lang="zh-CN" data-lang="zh">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={siteConfig.description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;1,100;1,200;1,300;1,400;1,500;1,600;1,700&display=swap"
      rel="stylesheet"
    />
    <title data-zh>徐帆 — AI PM / TPM 作品集</title>
    <title data-en>XuFan — AI PM / TPM Portfolio</title>
  </head>
  <body>
    <Header />
    <main>
      <Hero />
      <Education />
      <CaseStudies />
      <ThinkingVault />
      <Contact />
    </main>
    <Footer />
    <script src="../scripts/i18n.ts"></script>
  </body>
</html>
