---
import { siteConfig } from "../config";

const GITHUB_USERNAME = "Littlefun8";

interface GitHubRepo {
  name: string;
  description: string | null;
  html_url: string;
  language: string | null;
  stargazers_count: number;
  forks_count: number;
  size: number;
  topics: string[];
}

// Fetch repos at build time using GitHub REST API (no token needed for public repos)
let repos: GitHubRepo[] = [];
try {
  const response = await fetch(
    `https://api.github.com/users/${GITHUB_USERNAME}/repos?sort=updated&per_page=6&type=owner`,
    {
      headers: {
        "Accept": "application/vnd.github.v3+json",
        "User-Agent": "Astro-Portfolio",
      },
    }
  );
  if (response.ok) {
    const allRepos: GitHubRepo[] = await response.json();
    // Filter out forks and select top repos
    repos = allRepos
      .filter((r) => !r.fork && r.name !== GITHUB_USERNAME)
      .slice(0, 6);
  }
} catch (e) {
  console.warn("Failed to fetch GitHub repos:", e);
}

// Language color mapping
const langColors: Record<string, string> = {
  JavaScript: "#f1e05a",
  TypeScript: "#3178c6",
  Python: "#3572A5",
  Java: "#b07219",
  HTML: "#e34c26",
  CSS: "#563d7c",
  "Jupyter Notebook": "#DA5B0B",
  Shell: "#89e051",
  Vue: "#41b883",
  Astro: "#ff5a01",
};

function formatSize(kb: number): string {
  if (kb < 1024) return `${kb} KB`;
  return `${(kb / 1024).toFixed(1)} MB`;
}
---

{
  repos.length > 0 && (
    <section
      id="open-source"
      class="p-8 sm:p-12 md:p-16 lg:p-24"
      style={`--accent-color: ${siteConfig.accentColor}`}
    >
      <!-- Section heading -->
      <div class="mb-10 lg:mb-14">
        <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-6xl font-bold text-gray-900">
          <span data-zh>开源项目</span>
          <span data-en>Open Source</span>
        </h2>
        <p class="text-sm sm:text-base font-mono text-gray-400 mt-1">
          <span data-zh>Open Source Projects</span>
          <span data-en>开源项目</span>
        </p>
        <div
          class="w-16 h-1 mt-3 rounded-full"
          style={`background-color: ${siteConfig.accentColor}`}
        ></div>
      </div>

      <!-- Repo cards grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {repos.map((repo) => (
          <a
            href={repo.html_url}
            target="_blank"
            rel="noopener noreferrer"
            class="repo-card group block bg-white rounded-xl border border-gray-200 p-6 hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
          >
            {/* Repo name with icon */}
            <div class="flex items-center gap-2 mb-3">
              <svg
                aria-hidden="true"
                class="w-5 h-5 text-gray-400 flex-shrink-0 group-hover:text-gray-600 transition-colors"
                viewBox="0 0 16 16"
                fill="currentColor"
              >
                <path
                  fill-rule="evenodd"
                  d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5v-9zm10.5-1V9h-8c-.356 0-.694.074-1 .208V2.5a1 1 0 0 1 1-1h8zM5 12.25v3.25a.25.25 0 0 0 .4.2l1.45-1.087a.25.25 0 0 1 .3 0L8.6 15.7a.25.25 0 0 0 .4-.2v-3.25a.25.25 0 0 0-.25-.25h-3.5a.25.25 0 0 0-.25.25z"
                />
              </svg>
              <h3 class="text-base font-bold text-gray-900 truncate group-hover:text-blue-600 transition-colors">
                {repo.name}
              </h3>
            </div>

            {/* Description */}
            <p class="text-sm text-gray-600 leading-relaxed mb-4 line-clamp-2 min-h-[2.5rem]">
              {repo.description || "No description"}
            </p>

            {/* Stats row */}
            <div class="flex items-center justify-between text-xs text-gray-500">
              <div class="flex items-center gap-4">
                {/* Language */}
                {repo.language && (
                  <span class="flex items-center gap-1.5">
                    <span
                      class="w-3 h-3 rounded-full inline-block"
                      style={`background-color: ${langColors[repo.language] || "#8b949e"}`}
                    ></span>
                    {repo.language}
                  </span>
                )}
                {/* Stars */}
                <span class="flex items-center gap-1">
                  <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="currentColor">
                    <path
                      fill-rule="evenodd"
                      d="M8 .25a.75.75 0 01.673.418l1.882 3.815 4.21.612a.75.75 0 01.416 1.279l-3.046 2.97.719 4.192a.75.75 0 01-1.088.791L8 12.347l-3.766 1.98a.75.75 0 01-1.088-.79l.72-4.194L.818 6.374a.75.75 0 01.416-1.28l4.21-.611L7.327.668A.75.75 0 018 .25z"
                    />
                  </svg>
                  {repo.stargazers_count}
                </span>
                {/* Forks */}
                <span class="flex items-center gap-1">
                  <svg class="w-3.5 h-3.5" viewBox="0 0 16 16" fill="currentColor">
                    <path
                      fill-rule="evenodd"
                      d="M5 3.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm0 2.122a2.25 2.25 0 10-1.5 0v.878A2.25 2.25 0 005.75 8.5h1.5v2.128a2.251 2.251 0 101.5 0V8.5h1.5a2.25 2.25 0 002.25-2.25v-.878a2.25 2.25 0 10-1.5 0v.878a.75.75 0 01-.75.75h-4.5A.75.75 0 015 6.25v-.878zm3.75 7.378a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm3-8.75a.75.75 0 100-1.5.75.75 0 000 1.5z"
                    />
                  </svg>
                  {repo.forks_count}
                </span>
              </div>
              {/* Size */}
              <span>{formatSize(repo.size)}</span>
            </div>
          </a>
        ))}
      </div>

      {/* Link to all repos */}
      <div class="mt-8 text-center">
        <a
          href={`https://github.com/${GITHUB_USERNAME}?tab=repositories`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-medium border border-gray-300 text-gray-700 hover:border-gray-400 hover:shadow-sm hover:-translate-y-0.5 transition-all duration-200"
        >
          <span data-zh>查看更多项目</span>
          <span data-en>More Projects</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    </section>
  )
}
